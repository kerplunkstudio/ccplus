# cc+ Environment Configuration
# On first run, ./ccplus will generate this file interactively.
# You can also copy this template and modify manually.

# cc+ uses the Claude Code CLI subscription — no API key needed
WORKSPACE_PATH=/Users/you/Workspace
SDK_MODEL=sonnet
PORT=3000
CCPLUS_AUTH=local
SECRET_KEY=change-me-in-production

# Channel for updates (stable = production releases, latest = bleeding edge)
CCPLUS_CHANNEL=stable
