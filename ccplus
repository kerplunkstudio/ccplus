# Build React frontend
build_frontend() {
    header "Building frontend"

    cd "$SCRIPT_DIR/frontend"

    if [ ! -d "node_modules" ]; then
        warn "node_modules not found, running npm install..."
        run_with_spinner "Installing frontend dependencies..." "npm install --silent" || { error "npm install failed"; exit 1; }
    fi

    # Determine if this is first build (heuristic: no build dir yet)
    local build_msg="Building frontend..."
    if [ ! -d "build" ]; then
        build_msg="Building frontend (this may take 30-60s on first run)..."
    fi

    run_with_spinner "$build_msg" "npm run build" || { error "Frontend build failed"; exit 1; }

    cd "$SCRIPT_DIR"
}

# Build TypeScript backend
build_backend() {
    header "Building TypeScript backend"

    cd "$SCRIPT_DIR/backend-ts"

    if [ ! -d "node_modules" ]; then
        warn "node_modules not found, running npm install..."
        run_with_spinner "Installing backend dependencies..." "npm install --silent" || { error "npm install failed"; exit 1; }
    fi

    run_with_spinner "Building backend..." "npm run build" || { error "Backend build failed"; exit 1; }

    cd "$SCRIPT_DIR"
    ok "Backend built successfully"
}

# Deploy build output to static/chat/
deploy_static() {
    header "Deploying to static/chat/"

    mkdir -p "$SCRIPT_DIR/static/chat"
    rm -rf "$SCRIPT_DIR/static/chat/"*

    if [ ! -d "$SCRIPT_DIR/frontend/build" ]; then
        error "No frontend build found. Run: ./ccplus"
        exit 1
    fi

    cp -r "$SCRIPT_DIR/frontend/build/"* "$SCRIPT_DIR/static/chat/"
    ok "Static files deployed"
}

# Kill existing server on PORT
kill_server() {
    header "Stopping existing server"

    if ! server_running && ! lsof -ti:$PORT >/dev/null 2>&1; then
        ok "Server not running"
        return 0
    fi

    # Try PID file first
    if [ -f "$SERVER_PID_FILE" ]; then
        local pid
        pid=$(cat "$SERVER_PID_FILE" 2>/dev/null)
        if [ -n "$pid" ]; then
            info "Stopping server (PID: $pid)..."
            kill -TERM "$pid" 2>/dev/null || true

            # Wait up to 5s for process to exit
            local waited=0
            while [ $waited -lt 5 ]; do
                if ! kill -0 "$pid" 2>/dev/null; then
                    rm -f "$SERVER_PID_FILE"
                    ok "Server stopped"
                    return 0
                fi
                sleep 1
                waited=$((waited + 1))
            done

            # Force kill if still alive
            if kill -0 "$pid" 2>/dev/null; then
                warn "Force killing server (PID: $pid)..."
                kill -9 "$pid" 2>/dev/null || true
                sleep 1
            fi

            rm -f "$SERVER_PID_FILE"
        fi
    fi

    # Fallback to lsof for orphaned processes
    if lsof -ti:$PORT >/dev/null 2>&1; then
        warn "Found orphaned process on port $PORT (PID file was stale/missing)"
        info "Killing processes on port $PORT..."
        lsof -ti:$PORT | xargs kill -TERM 2>/dev/null || true
        sleep 2

        # Force kill if still running
        if lsof -ti:$PORT >/dev/null 2>&1; then
            warn "Force killing processes on port $PORT..."
            lsof -ti:$PORT | xargs kill -9 2>/dev/null || true
            sleep 1
        fi

        if lsof -ti:$PORT >/dev/null 2>&1; then
            error "Failed to free port $PORT"
            exit 1
        fi
    fi

    ok "Port $PORT is free"
}

# Start backend server
start_server() {
    header "Starting server"

    mkdir -p "$SCRIPT_DIR/logs"

    # Ensure backend is built
    if [ ! -d "$SCRIPT_DIR/backend-ts/dist" ] || [ -z "$(ls -A "$SCRIPT_DIR/backend-ts/dist" 2>/dev/null)" ]; then
        warn "Backend not built, building TypeScript first..."
        build_backend
    fi

    nohup node "$SCRIPT_DIR/backend-ts/dist/server.js" > "$SCRIPT_DIR/logs/server.log" 2>&1 &
    SERVER_PID=$!

    info "Server starting (PID: $SERVER_PID)"

    # Health check
    info "Waiting for health check at localhost:$PORT/health..."
    max_wait=15
    waited=0
    while [ $waited -lt $max_wait ]; do
        status=$(curl -s -o /dev/null -w "%{http_code}" "http://localhost:$PORT/health" 2>/dev/null || echo "000")
        if [ "$status" = "200" ]; then
            ok "Server is healthy (PID: $SERVER_PID)"
            echo ""
            echo "${GREEN}${BOLD}cc+ v${VERSION} deployed!${RESET}"
            echo ""
            echo "  URL:  ${BOLD}http://localhost:$PORT${RESET}"
            echo "  Logs: tail -f logs/server.log"
            echo ""
            return 0
        fi
        sleep 1
        waited=$((waited + 1))
    done

    error "Server failed health check after ${max_wait}s"
    echo "Last 20 lines of logs:" >&2
    tail -20 "$SCRIPT_DIR/logs/server.log" 2>/dev/null || true
    exit 1
}

# Install Electron dependencies
install_electron() {
    header "Installing Electron dependencies"

    if [ ! -d "$SCRIPT_DIR/node_modules" ]; then
        cd "$SCRIPT_DIR"
        run_with_spinner "Installing Electron dependencies..." "npm install --silent" || { error "npm install failed"; exit 1; }
    else
        ok "Electron dependencies already installed"
    fi
}

# Launch desktop app (exclusive mode - stops existing services)
launch_desktop() {
    header "Launching desktop app"

    # Ensure electron is installed
    install_electron

    # Build frontend first if needed
    if [ ! -d "$SCRIPT_DIR/static/chat" ] || [ -z "$(ls -A "$SCRIPT_DIR/static/chat" 2>/dev/null)" ]; then
        warn "No static build found, building frontend first..."
        build_frontend
        deploy_static
    fi

    # Stop any running web server (desktop app starts its own)
    if lsof -ti:$PORT >/dev/null 2>&1; then
        info "Stopping web server (desktop app will start its own)..."
        kill_server
    fi

    # Note: No separate worker to stop - TS backend runs SDK in-process

    info "Starting cc+ Desktop..."
    cd "$SCRIPT_DIR"
    npm run electron:dev
}

# Launch desktop app (parallel mode - runs alongside web server)
launch_desktop_parallel() {
    header "Launching desktop app (parallel mode)"

    # Ensure electron is installed
    install_electron

    # Build frontend first if needed
    if [ ! -d "$SCRIPT_DIR/static/chat" ] || [ -z "$(ls -A "$SCRIPT_DIR/static/chat" 2>/dev/null)" ]; then
        warn "No static build found, building frontend first..."
        build_frontend
        deploy_static
    fi

    # Note: No separate worker needed - TS backend runs SDK in-process

    # Check if web server is running
    if lsof -ti:$PORT >/dev/null 2>&1; then
        info "Web server running on port $PORT"
        info "Desktop will run on port 4001"
    else
        info "No web server running, desktop will use port 4001"
    fi

    info "Starting cc+ Desktop (parallel mode)..."
    cd "$SCRIPT_DIR"
    # Use port 4001 for desktop to avoid conflict with web server
    PORT=4001 npm run electron:dev
}

# Check if setup is needed
needs_setup() {
    [ ! -f ".env" ] || [ ! -d "frontend/node_modules" ] || [ ! -d "backend-ts/node_modules" ]
}

# Run setup
run_setup() {
    header "Setting up cc+"

    # Check prerequisites
    if ! command -v python3 >/dev/null 2>&1; then
        error "Python 3 not found"
        exit 1
    fi

    py_version=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
    py_major=$(echo "$py_version" | cut -d. -f1)
    py_minor=$(echo "$py_version" | cut -d. -f2)

    if [ "$py_major" -ne 3 ] || [ "$py_minor" -lt 12 ]; then
        error "Python 3.12+ required (found $py_version)"
        exit 1
    fi

    if ! command -v node >/dev/null 2>&1; then
        error "Node.js not found"
        exit 1
    fi

    node_major=$(node -v | sed 's/v//' | cut -d. -f1)
    if [ "$node_major" -lt 18 ]; then
        error "Node.js 18+ required (found $(node -v))"
        exit 1
    fi

    if ! command -v npm >/dev/null 2>&1; then
        error "npm not found"
        exit 1
    fi

    # Create venv if needed
    if [ ! -d "venv" ]; then
        run_with_spinner "Creating Python virtual environment..." python3 -m venv venv || exit 1
    fi

    # Install Python dependencies
    source venv/bin/activate
    run_with_spinner "Installing Python dependencies..." "pip install -q --upgrade pip && pip install -q -r requirements.txt" || exit 1

    # Install frontend dependencies
    run_with_spinner "Installing frontend dependencies..." "cd frontend && npm install --silent && cd '$SCRIPT_DIR'" || exit 1

    # Install backend dependencies
    run_with_spinner "Installing backend dependencies..." "cd backend-ts && npm install --silent && cd '$SCRIPT_DIR'" || exit 1

    # Build backend
    run_with_spinner "Building TypeScript backend..." "cd backend-ts && npm run build && cd '$SCRIPT_DIR'" || exit 1

    # Setup .env file
    if [ ! -f ".env" ]; then
        interactive_env_setup
    fi

    # Check Claude Code CLI is available
    if ! command -v claude >/dev/null 2>&1; then
        error "Claude Code CLI not found. Install it first: npm install -g @anthropic-ai/claude-code"
        exit 1
    fi

    ok "Setup complete!"
}

# Interactive .env setup
interactive_env_setup() {
    header "Environment configuration"

    # Detect if stdin is non-interactive
    if [ ! -t 0 ]; then
        info "Non-interactive mode detected, using defaults"
        WORKSPACE_PATH="$HOME/Workspace"
        SDK_MODEL="sonnet"
        SECRET_KEY=$(openssl rand -hex 32 2>/dev/null || echo "ccplus-dev-secret-change-me")

        cat > .env <<EOF
# cc+ uses the Claude Code CLI subscription — no API key needed
WORKSPACE_PATH=$WORKSPACE_PATH
SDK_MODEL=$SDK_MODEL
PORT=4000
CCPLUS_AUTH=local
SECRET_KEY=$SECRET_KEY

# Channel for updates (stable = production releases, latest = bleeding edge)
CCPLUS_CHANNEL=stable
EOF
        ok ".env created with defaults"
        return
    fi

    echo ""
    echo "Setting up cc+ for the first time..."
    echo ""

    # Smart default for workspace path
    WORKSPACE_DEFAULT="$HOME/Workspace"
    for candidate in "$HOME/Workspace" "$HOME/Projects" "$HOME/Developer" "$HOME/Code" "$HOME/repos"; do
        if [ -d "$candidate" ]; then
            WORKSPACE_DEFAULT="$candidate"
            break
        fi
    done

    read -p "Where are your projects? [default: $WORKSPACE_DEFAULT] > " WORKSPACE_INPUT
    WORKSPACE_PATH="${WORKSPACE_INPUT:-$WORKSPACE_DEFAULT}"

    echo ""
    echo "Which model should cc+ use by default?"
    echo "  1) sonnet  (recommended, best coding model)"
    echo "  2) opus    (deepest reasoning, slower)"
    echo "  3) haiku   (fastest, most affordable)"
    read -p "[default: 1] > " MODEL_INPUT
    case "${MODEL_INPUT:-1}" in
        1) SDK_MODEL="sonnet" ;;
        2) SDK_MODEL="opus" ;;
        3) SDK_MODEL="haiku" ;;
        *) SDK_MODEL="sonnet" ;;
    esac

    # Generate secret key
    SECRET_KEY=$(openssl rand -hex 32 2>/dev/null || echo "ccplus-dev-secret-change-me")

    # Write .env file
    cat > .env <<EOF
# cc+ uses the Claude Code CLI subscription — no API key needed
WORKSPACE_PATH=$WORKSPACE_PATH
SDK_MODEL=$SDK_MODEL
PORT=4000
CCPLUS_AUTH=local
SECRET_KEY=$SECRET_KEY

# Channel for updates (stable = production releases, latest = bleeding edge)
CCPLUS_CHANNEL=stable
EOF

    ok ".env created successfully"
    echo ""
}

# Run doctor command
run_doctor() {
    header "Running diagnostics"

    local exit_code=0

    echo ""
    echo "${BOLD}System${RESET}"
    echo ""

    # Python version
    if command -v python3 >/dev/null 2>&1; then
        py_version=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
        py_major=$(echo "$py_version" | cut -d. -f1)
        py_minor=$(echo "$py_version" | cut -d. -f2)
        if [ "$py_major" -eq 3 ] && [ "$py_minor" -ge 12 ]; then
            pass "Python $py_version"
        else
            fail "Python $py_version (need 3.12+)"
            exit_code=1
        fi
    else
        fail "Python 3 not found"
        exit_code=1
    fi

    # Node version
    if command -v node >/dev/null 2>&1; then
        node_version=$(node -v)
        node_major=$(echo "$node_version" | sed 's/v//' | cut -d. -f1)
        if [ "$node_major" -ge 18 ]; then
            pass "Node $node_version"
        else
            fail "Node $node_version (need 18+)"
            exit_code=1
        fi
    else
        fail "Node.js not found"
        exit_code=1
    fi

    # npm
    if command -v npm >/dev/null 2>&1; then
        npm_version=$(npm -v)
        pass "npm $npm_version"
    else
        fail "npm not found"
        exit_code=1
    fi

    # Claude CLI
    if command -v claude >/dev/null 2>&1; then
        claude_version=$(claude --version 2>&1 | head -1 || echo "unknown")
        pass "Claude CLI ($claude_version)"
    else
        fail "Claude CLI not found"
        exit_code=1
    fi

    echo ""
    echo "${BOLD}Environment${RESET}"
    echo ""

    # .env exists
    if [ -f ".env" ]; then
        pass ".env file exists"

        # Check workspace path
        source .env 2>/dev/null || true
        if [ -n "$WORKSPACE_PATH" ] && [ -d "$WORKSPACE_PATH" ]; then
            pass "WORKSPACE_PATH exists: $WORKSPACE_PATH"
        elif [ -n "$WORKSPACE_PATH" ]; then
            warn "WORKSPACE_PATH set but directory not found: $WORKSPACE_PATH"
        else
            warn "WORKSPACE_PATH not set in .env"
        fi

        # Check secret key
        if [ "$SECRET_KEY" = "change-me-in-production" ] || [ "$SECRET_KEY" = "ccplus-dev-secret-change-me" ]; then
            warn "SECRET_KEY is default value (not secure for production)"
        elif [ -n "$SECRET_KEY" ]; then
            pass "SECRET_KEY is configured"
        else
            warn "SECRET_KEY not set in .env"
        fi
    else
        fail ".env file not found"
        exit_code=1
    fi

    echo ""
    echo "${BOLD}Services${RESET}"
    echo ""

    # Port availability
    if lsof -ti:$PORT >/dev/null 2>&1; then
        pass "Port $PORT is in use (server likely running)"
    else
        warn "Port $PORT is free (server not running)"
    fi

    # Note: No separate worker in TS backend - SDK runs in-process

    echo ""
    echo "${BOLD}Build${RESET}"
    echo ""

    # Static build exists
    if [ -f "static/chat/index.html" ]; then
        pass "Frontend build exists"

        # Check staleness
        if [ -d "frontend/src" ]; then
            stale_count=$(find frontend/src -newer static/chat/index.html 2>/dev/null | wc -l)
            if [ "$stale_count" -gt 0 ]; then
                warn "Frontend source is newer than build (rebuild recommended)"
            else
                pass "Frontend build is up to date"
            fi
        fi
    else
        fail "Frontend build not found"
        exit_code=1
    fi

    # Backend build exists
    if [ -f "backend-ts/dist/server.js" ]; then
        pass "Backend build exists"

        # Check staleness
        if [ -d "backend-ts/src" ]; then
            stale_count=$(find backend-ts/src -newer backend-ts/dist/server.js 2>/dev/null | wc -l)
            if [ "$stale_count" -gt 0 ]; then
                warn "Backend source is newer than build (rebuild recommended)"
            else
                pass "Backend build is up to date"
            fi
        fi
    else
        fail "Backend build not found"
        exit_code=1
    fi

    echo ""
    echo "${BOLD}Database${RESET}"
    echo ""

    # Database exists
    if [ -f "data/ccplus.db" ]; then
        pass "Database file exists"

        # Table count
        if command -v sqlite3 >/dev/null 2>&1; then
            table_count=$(sqlite3 data/ccplus.db "SELECT COUNT(*) FROM sqlite_master WHERE type='table'" 2>/dev/null || echo "0")
            if [ "$table_count" -gt 0 ]; then
                pass "Database has $table_count tables"
            else
                warn "Database has no tables"
            fi

            # Conversation count
            conv_count=$(sqlite3 data/ccplus.db "SELECT COUNT(*) FROM conversations" 2>/dev/null || echo "0")
            pass "$conv_count conversations recorded"

            # Tool event count
            tool_count=$(sqlite3 data/ccplus.db "SELECT COUNT(*) FROM tool_usage" 2>/dev/null || echo "0")
            pass "$tool_count tool events recorded"
        else
            warn "sqlite3 not installed, cannot check database contents"
        fi
    else
        warn "Database not found (will be created on first run)"
    fi

    echo ""
    if [ $exit_code -eq 0 ]; then
        echo "${GREEN}${BOLD}All checks passed!${RESET}"
    else
        echo "${RED}${BOLD}Some checks failed.${RESET}"
    fi
    echo ""

    exit $exit_code
}

# Calculate uptime from PID
get_uptime() {
    local pid=$1
    if ! kill -0 "$pid" 2>/dev/null; then
        echo "N/A"
        return
    fi

    # Get process start time (macOS compatible)
    local start_time
    start_time=$(ps -p "$pid" -o lstart= 2>/dev/null | xargs -I {} date -j -f "%a %b %d %T %Y" "{}" "+%s" 2>/dev/null || echo "")
    if [ -z "$start_time" ]; then
        echo "N/A"
        return
    fi

    local now
    now=$(date +%s)
    local elapsed=$((now - start_time))

    # Format uptime
    local days=$((elapsed / 86400))
    local hours=$(( (elapsed % 86400) / 3600 ))
    local minutes=$(( (elapsed % 3600) / 60 ))

    if [ $days -gt 0 ]; then
        echo "${days}d ${hours}h ${minutes}m"
    elif [ $hours -gt 0 ]; then
        echo "${hours}h ${minutes}m"
    else
        echo "${minutes}m"
    fi
}

# Run status command
run_status() {
    header "cc+ Status"

    echo ""
    echo "${BOLD}Version${RESET}"
    echo "  $VERSION"
    echo ""

    echo "${BOLD}Services${RESET}"
    echo ""

    # Server status
    if server_running; then
        local server_pid
        server_pid=$(cat "$SERVER_PID_FILE")
        local server_uptime
        server_uptime=$(get_uptime "$server_pid")
        echo "  ${GREEN}●${RESET} Node.js Server"
        echo "    PID:    $server_pid"
        echo "    Port:   $PORT"
        echo "    Uptime: $server_uptime"

        # Try to get connected clients count from health endpoint
        local clients
        clients=$(curl -s "http://localhost:$PORT/health" 2>/dev/null | node -e "process.stdin.on('data', d => console.log(JSON.parse(d).connected_clients || 0))" 2>/dev/null || echo "N/A")
        echo "    Clients: $clients"
    else
        echo "  ${RED}●${RESET} Node.js Server"
        echo "    Status: ${RED}not running${RESET}"
        echo "    Port:   $PORT"
    fi

    echo ""
}

# Run logs command
run_logs() {
    local target="${1:-all}"

    case "$target" in
        server)
            if [ ! -f "$SCRIPT_DIR/logs/server.log" ]; then
                error "Server log not found: $SCRIPT_DIR/logs/server.log"
                exit 1
            fi
            info "Tailing server log (Ctrl+C to stop)..."
            tail -f "$SCRIPT_DIR/logs/server.log" | sed "s/^/${BLUE}[server]${RESET} /"
            ;;
        all|*)
            if [ ! -f "$SCRIPT_DIR/logs/server.log" ]; then
                error "Server log not found in $SCRIPT_DIR/logs/"
                exit 1
            fi

            info "Tailing server log (Ctrl+C to stop)..."
            tail -f "$SCRIPT_DIR/logs/server.log" | sed "s/^/${BLUE}[server]${RESET} /"
            ;;
    esac
}

# Check for updates
check_for_updates() {
    header "Checking for updates"

    # Read channel from .env
    CHANNEL="${CCPLUS_CHANNEL:-stable}"
    if [ -f ".env" ]; then
        source .env 2>/dev/null || true
        CHANNEL="${CCPLUS_CHANNEL:-stable}"
    fi

    # Read current version
    CURRENT_VERSION="$VERSION"
    info "Current version: $CURRENT_VERSION"
    info "Channel: $CHANNEL"

    # Fetch latest tags from git
    info "Fetching latest updates..."
    if ! git fetch --tags --quiet 2>/dev/null; then
        warn "Failed to fetch updates (not a git repo or no network)"
        return 1
    fi

    if [ "$CHANNEL" = "stable" ]; then
        # For stable: compare against latest git tag
        LATEST_VERSION=$(git tag --sort=-v:refname 2>/dev/null | head -1)
        if [ -z "$LATEST_VERSION" ]; then
            info "No tagged releases found"
            return 1
        fi

        # Strip 'v' prefix from tag for comparison
        LATEST_VERSION_CLEAN="${LATEST_VERSION#v}"

        if [ "$CURRENT_VERSION" = "$LATEST_VERSION_CLEAN" ]; then
            ok "You are up to date ($LATEST_VERSION)"
            return 1
        else
            info "${GREEN}Update available: v$CURRENT_VERSION → $LATEST_VERSION${RESET}"
            return 0
        fi
    else
        # For latest: compare against origin/main
        if ! git rev-parse --verify origin/main >/dev/null 2>&1; then
            warn "Cannot find origin/main branch"
            return 1
        fi

        COMMITS_BEHIND=$(git rev-list HEAD..origin/main --count 2>/dev/null || echo "0")
        if [ "$COMMITS_BEHIND" = "0" ]; then
            ok "You are up to date (latest from main)"
            return 1
        else
            info "${GREEN}Update available: $COMMITS_BEHIND commit(s) behind origin/main${RESET}"
            return 0
        fi
    fi
}

# Run update
run_update() {
    # Check if update is available
    if ! check_for_updates; then
        echo ""
        ok "No update needed"
        return 0
    fi

    echo ""
    header "Updating cc+"

    # Read channel from .env
    CHANNEL="${CCPLUS_CHANNEL:-stable}"
    if [ -f ".env" ]; then
        source .env 2>/dev/null || true
        CHANNEL="${CCPLUS_CHANNEL:-stable}"
    fi

    # Check for local modifications
    if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
        error "You have uncommitted changes. Commit or stash them before updating."
        echo ""
        git status --short
        echo ""
        exit 1
    fi

    # Record versions before update
    BEFORE_VERSION="$VERSION"

    # Pull updates based on channel
    if [ "$CHANNEL" = "stable" ]; then
        LATEST_VERSION=$(git tag --sort=-v:refname 2>/dev/null | head -1)
        info "Updating to stable release: $LATEST_VERSION"
        if ! git checkout "$LATEST_VERSION" 2>&1; then
            error "Failed to checkout $LATEST_VERSION"
            exit 1
        fi
    else
        info "Updating to latest from main branch"
        if ! git pull --rebase origin main 2>&1; then
            error "Failed to pull from origin/main"
            exit 1
        fi
    fi

    # Read new version
    AFTER_VERSION=$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null || echo "dev")

    # Check if requirements.txt changed
    if git diff --name-only HEAD@{1} HEAD 2>/dev/null | grep -q "^requirements.txt$"; then
        info "Dependencies changed, reinstalling Python packages..."
        source venv/bin/activate 2>/dev/null || true
        run_with_spinner "Reinstalling Python dependencies..." "pip install -q --upgrade pip && pip install -q -r requirements.txt" || exit 1
    fi

    # Check if frontend/package.json changed
    if git diff --name-only HEAD@{1} HEAD 2>/dev/null | grep -q "^frontend/package.json$"; then
        info "Frontend dependencies changed, reinstalling npm packages..."
        run_with_spinner "Reinstalling frontend dependencies..." "cd frontend && npm install --silent && cd '$SCRIPT_DIR'" || exit 1
    fi

    # Always rebuild frontend and backend
    build_backend
    build_frontend
    deploy_static

    # Restart server
    kill_server
    start_server

    echo ""
    ok "Update complete: v$BEFORE_VERSION → v$AFTER_VERSION"
    echo ""
}

# Run release command
run_release() {
    local bump_type="${1:-}"

    if [ -z "$bump_type" ]; then
        error "Version bump type required"
        echo ""
        echo "Usage: ./ccplus release [patch|minor|major]"
        echo ""
        echo "Examples:"
        echo "  ./ccplus release patch    # 1.1.0 -> 1.1.1"
        echo "  ./ccplus release minor    # 1.1.0 -> 1.2.0"
        echo "  ./ccplus release major    # 1.1.0 -> 2.0.0"
        echo ""
        exit 1
    fi

    # Validate bump type
    if [[ ! "$bump_type" =~ ^(patch|minor|major)$ ]]; then
        error "Invalid bump type: $bump_type"
        echo ""
        echo "Valid types: patch, minor, major"
        echo ""
        exit 1
    fi

    # Check for uncommitted changes
    if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
        error "You have uncommitted changes. Commit or stash them before creating a release."
        echo ""
        git status --short
        echo ""
        exit 1
    fi

    # Read current version
    CURRENT_VERSION="$VERSION"
    info "Current version: $CURRENT_VERSION"

    # Parse version components
    if [[ ! "$CURRENT_VERSION" =~ ^([0-9]+)\.([0-9]+)\.([0-9]+)$ ]]; then
        error "Invalid version format in VERSION file: $CURRENT_VERSION"
        exit 1
    fi

    local major="${BASH_REMATCH[1]}"
    local minor="${BASH_REMATCH[2]}"
    local patch="${BASH_REMATCH[3]}"

    # Bump version
    case "$bump_type" in
        patch)
            patch=$((patch + 1))
            ;;
        minor)
            minor=$((minor + 1))
            patch=0
            ;;
        major)
            major=$((major + 1))
            minor=0
            patch=0
            ;;
    esac

    NEW_VERSION="${major}.${minor}.${patch}"

    header "Creating release v$NEW_VERSION"

    # Update VERSION file
    echo "$NEW_VERSION" > "$SCRIPT_DIR/VERSION"
    ok "Updated VERSION file: $CURRENT_VERSION -> $NEW_VERSION"

    # Create git tag
    local tag="v$NEW_VERSION"

    info "Creating git tag: $tag"
    if git tag -a "$tag" -m "Release $NEW_VERSION"; then
        ok "Tag created: $tag"
    else
        error "Failed to create tag"
        # Restore VERSION file
        echo "$CURRENT_VERSION" > "$SCRIPT_DIR/VERSION"
        exit 1
    fi

    echo ""
    ok "Release v$NEW_VERSION ready!"
    echo ""
    echo "To publish this release:"
    echo "  1. Review the changes: git show $tag"
    echo "  2. Push the tag:       git push origin $tag"
    echo ""
    echo "After pushing the tag, users can update to this version with:"
    echo "  ./ccplus update"
    echo ""
}

# Usage
show_usage() {
    cat <<EOF
cc+ - Unified launcher and deployment tool

Usage: ./ccplus [command]

Commands:
  (none) or start  Full deploy: build frontend + backend + deploy + restart server
                   On first run: setup + configure + build + start
  status           Show service status (version, uptime, PID, clients)
  logs [target]    Tail logs (target: all or server. default: all)
  doctor           Run system diagnostics
  version          Show version information
  check-update     Check if an update is available
  update           Update cc+ to the latest version
  release [type]   Create a new release (type: patch, minor, major)
  server           Restart Node.js server
  frontend         Build + deploy frontend only (no server restart)
  backend          Build TypeScript backend only (no server restart)
  desktop          Launch Electron desktop app (stops existing services)
  desktop-parallel Launch desktop app in parallel with web server
  stop             Stop Node.js server
  setup            Force re-run setup
  help             Show this help message

Installation:
  One-line installer (clones repo, runs setup, starts server):
    curl -fsSL https://raw.githubusercontent.com/mjfuentes/ccplus/main/install.sh | bash

Examples:
  ./ccplus              # First run: setup + build + start
  ./ccplus              # Subsequent: smart deploy
  ./ccplus status       # Show service status
  ./ccplus logs         # Tail all logs
  ./ccplus logs server  # Tail server log only
  ./ccplus doctor       # Check system health
  ./ccplus version      # Show version
  ./ccplus check-update # Check for updates
  ./ccplus update       # Update to latest version
  ./ccplus release patch # Create patch release (1.1.0 -> 1.1.1)
  ./ccplus frontend     # Rebuild frontend only
  ./ccplus desktop      # Launch desktop app
  ./ccplus stop         # Stop everything
EOF
}

# Main
COMMAND="${1:-start}"

case "$COMMAND" in
    start|"")
        if needs_setup; then
            run_setup
        fi
        build_backend
        build_frontend
        deploy_static
        kill_server
        start_server
        ;;
    status)
        run_status
        ;;
    logs)
        run_logs "${2:-all}"
        ;;
    doctor)
        run_doctor
        ;;
    version)
        # Read channel from .env if exists
        CHANNEL="${CCPLUS_CHANNEL:-stable}"
        if [ -f ".env" ]; then
            source .env 2>/dev/null || true
            CHANNEL="${CCPLUS_CHANNEL:-stable}"
        fi

        # Get git SHA if in git repo
        GIT_SHA=""
        if git rev-parse --short HEAD >/dev/null 2>&1; then
            GIT_SHA=$(git rev-parse --short HEAD)
        fi

        echo "${BOLD}cc+ version ${VERSION}${RESET}"
        echo "Channel: ${CHANNEL}"
        if [ -n "$GIT_SHA" ]; then
            echo "Git SHA: ${GIT_SHA}"
        fi
        ;;
    check-update)
        if check_for_updates; then
            echo ""
            echo "Run ${BOLD}./ccplus update${RESET} to install the update"
            echo ""
        fi
        ;;
    update)
        run_update
        ;;
    release)
        run_release "${2:-}"
        ;;
    frontend)
        build_frontend
        deploy_static
        ok "Frontend deployed (server not restarted)"
        echo ""
        echo "  ${BOLD}Hard refresh your browser (Cmd+Shift+R) to load new assets${RESET}"
        echo ""
        ;;
    backend)
        build_backend
        ok "Backend built (server not restarted)"
        echo ""
        echo "  ${BOLD}Run './ccplus server' to restart with new backend${RESET}"
        echo ""
        ;;
    server)
        kill_server
        start_server
        ;;
    desktop)
        launch_desktop
        ;;
    desktop-parallel)
        launch_desktop_parallel
        ;;
    stop)
        kill_server
        ;;
    setup)
        run_setup
        ;;
    help|-h|--help)
        show_usage
        ;;
    *)
        error "Unknown command: $COMMAND"
        show_usage
        exit 1
        ;;
esac

# Calculate uptime from PID
get_uptime() {
    local pid=$1
    if ! kill -0 "$pid" 2>/dev/null; then
        echo "N/A"
        return
    fi

    # Get process start time (macOS compatible)
    local start_time
    start_time=$(ps -p "$pid" -o lstart= 2>/dev/null | xargs -I {} date -j -f "%a %b %d %T %Y" "{}" "+%s" 2>/dev/null || echo "")
    if [ -z "$start_time" ]; then
        echo "N/A"
        return
    fi

    local now
    now=$(date +%s)
    local elapsed=$((now - start_time))

    # Format uptime
    local days=$((elapsed / 86400))
    local hours=$(( (elapsed % 86400) / 3600 ))
    local minutes=$(( (elapsed % 3600) / 60 ))

    if [ $days -gt 0 ]; then
        echo "${days}d ${hours}h ${minutes}m"
    elif [ $hours -gt 0 ]; then
        echo "${hours}h ${minutes}m"
    else
        echo "${minutes}m"
    fi
}

# Run status command
run_status() {
    header "cc+ Status"

    echo ""
    echo "${BOLD}Version${RESET}"
    echo "  $VERSION"
    echo ""

    echo "${BOLD}Services${RESET}"
    echo ""

    # Server status
    if server_running; then
        local server_pid
        server_pid=$(cat "$SERVER_PID_FILE")
        local server_uptime
        server_uptime=$(get_uptime "$server_pid")
        echo "  ${GREEN}●${RESET} Node.js Server"
        echo "    PID:    $server_pid"
        echo "    Port:   $PORT"
        echo "    Uptime: $server_uptime"

        # Try to get connected clients count from health endpoint
        local clients
        clients=$(curl -s "http://localhost:$PORT/health" 2>/dev/null | node -e "process.stdin.on('data', d => console.log(JSON.parse(d).connected_clients || 0))" 2>/dev/null || echo "N/A")
        echo "    Clients: $clients"
    else
        echo "  ${RED}●${RESET} Node.js Server"
        echo "    Status: ${RED}not running${RESET}"
        echo "    Port:   $PORT"
    fi

    echo ""
}

# Run logs command
run_logs() {
    local target="${1:-all}"

    case "$target" in
        server)
            if [ ! -f "$SCRIPT_DIR/logs/server.log" ]; then
                error "Server log not found: $SCRIPT_DIR/logs/server.log"
                exit 1
            fi
            info "Tailing server log (Ctrl+C to stop)..."
            tail -f "$SCRIPT_DIR/logs/server.log" | sed "s/^/${BLUE}[server]${RESET} /"
            ;;
        all|*)
            if [ ! -f "$SCRIPT_DIR/logs/server.log" ]; then
                error "Server log not found in $SCRIPT_DIR/logs/"
                exit 1
            fi

            info "Tailing server log (Ctrl+C to stop)..."
            tail -f "$SCRIPT_DIR/logs/server.log" | sed "s/^/${BLUE}[server]${RESET} /"
            ;;
    esac
}
