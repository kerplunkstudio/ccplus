#!/bin/bash
# cc+ launcher — build, deploy, and run desktop app
# Usage: ./ccplus

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Activate venv
if [ ! -f "venv/bin/activate" ]; then
    echo "Virtual environment not found. Run ./setup.sh first." >&2
    exit 1
fi

source venv/bin/activate

# Build frontend
echo "Building frontend..."
cd frontend
npm run build >/dev/null 2>&1 || { echo "Frontend build failed" >&2; exit 1; }
cd "$SCRIPT_DIR"

# Deploy to static/chat/
echo "Deploying static files..."
mkdir -p static/chat
rm -rf static/chat/*
cp -r frontend/build/* static/chat/

# Launch desktop app in parallel mode
echo "Starting cc+ Desktop..."
exec ./deploy.sh desktop-parallel
