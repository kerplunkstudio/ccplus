#!/bin/bash
# cc+ unified launcher and deployment tool
# Usage: ./ccplus [command]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Read version from VERSION file
VERSION=$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null || echo "dev")

PORT="${PORT:-4000}"

# Colors (graceful degradation for non-interactive terminals)
if [ -t 1 ] && command -v tput >/dev/null 2>&1; then
    RED=$(tput setaf 1)
    GREEN=$(tput setaf 2)
    YELLOW=$(tput setaf 3)
    BLUE=$(tput setaf 4)
    BOLD=$(tput bold)
    RESET=$(tput sgr0)
else
    RED="" GREEN="" YELLOW="" BLUE="" BOLD="" RESET=""
fi

info()  { echo "${BLUE}[info]${RESET}  $*"; }
ok()    { echo "${GREEN}[ok]${RESET}    $*"; }
warn()  { echo "${YELLOW}[warn]${RESET}  $*"; }
error() { echo "${RED}[error]${RESET} $*" >&2; }
pass()  { echo "${GREEN}[PASS]${RESET}  $*"; }
fail()  { echo "${RED}[FAIL]${RESET}  $*" >&2; }
header() {
    echo ""
    echo "${BOLD}--- $* ---${RESET}"
}

# Run command with spinner/progress indicator
# Usage: run_with_spinner "message" command args...
run_with_spinner() {
    local message="$1"
    shift
    local cmd="$*"

    # Create temp log file
    local log_file
    log_file=$(mktemp)
    trap "rm -f $log_file" RETURN

    # Non-interactive terminal: fall back to simple logging
    if [ ! -t 1 ]; then
        info "$message"
        if eval "$cmd" >"$log_file" 2>&1; then
            ok "$message (completed)"
            return 0
        else
            error "$message (failed)"
            echo "Last 20 lines of output:" >&2
            tail -20 "$log_file" >&2
            return 1
        fi
    fi

    # Interactive terminal: show spinner
    local spinner_chars="⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
    local spin_delay=0.1
    local pid
    local start_time
    start_time=$(date +%s)

    # Start command in background
    eval "$cmd" >"$log_file" 2>&1 &
    pid=$!

    # Spinner loop
    local i=0
    while kill -0 $pid 2>/dev/null; do
        local elapsed=$(($(date +%s) - start_time))
        local spinner_char="${spinner_chars:i++%${#spinner_chars}:1}"
        printf "\r${BLUE}%s${RESET} %s (%ds)" "$spinner_char" "$message" "$elapsed" >&2
        sleep "$spin_delay"
    done

    # Clear spinner line
    printf "\r\033[K" >&2

    # Check exit status
    wait $pid
    local exit_code=$?

    local elapsed=$(($(date +%s) - start_time))

    if [ $exit_code -eq 0 ]; then
        ok "$message (${elapsed}s)"
        return 0
    else
        error "$message (failed after ${elapsed}s)"
        echo ""
        echo "Last 20 lines of output:" >&2
        tail -20 "$log_file" >&2
        echo ""
        return 1
    fi
}

# Detect Python (prefer venv)
detect_python() {
    if [ -f "$SCRIPT_DIR/venv/bin/python" ]; then
        PYTHON="$SCRIPT_DIR/venv/bin/python"
        info "Using venv Python: $PYTHON"
    elif command -v python3 >/dev/null 2>&1; then
        PYTHON="python3"
        warn "No venv found, using system python3"
    else
        error "Python not found. Create a venv: python3 -m venv venv"
        exit 1
    fi
}

